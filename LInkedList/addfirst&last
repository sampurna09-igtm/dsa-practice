class Node{
    int data;
    Node next;
    Node(int data){
        this.data=data;
        this.next=null;
    }
}
class LinkedList{
    Node head;
    public void addFirst(int data){
        Node n = new Node(data);
        if(head==null){
            head=n;
            return;
        }
        n.next=head;
        head=n;
    }
    public void addLast(int data){
         Node n = new Node(data);
        if(head==null){
            head=n;
            return;
        }
        Node curr = head;
        while(curr.next!=null){
            curr = curr.next;
        }
        curr.next=n;
    }
    public void print(){
        if(head==null){
            System.out.println("List is empty");
            return;
        }
        Node curr = head;
        while(curr!=null){
            System.out.print(curr.data+"->");
            curr=curr.next;
        }
        System.out.println("Null");
    }
    public static void main(String[]args){
        LinkedList ll = new LinkedList();
        ll.addFirst(3);
        ll.addFirst(2);
        ll.print();
        ll.addFirst(1);
        ll.addLast(4);
        ll.print();

    }
}
